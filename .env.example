# ShareSlices deployment configuration
# Copy to .env for local overrides. Replace every value marked "required".
# Active non-required entries show their defaults. Commented entries are optional.
# Values marked "required" are sensitive placeholders and must not be used in production.

# API and public addresses
NODE_ENV=development
PORT=7456
WEB_ORIGIN=http://127.0.0.1:5173
WEB_CANONICAL_HOST=127.0.0.1
API_ORIGIN=http://127.0.0.1:7456
VIEWER_ORIGIN=http://127.0.0.1:5173
GALLERY_ENABLED=false
GALLERY_CONTENT_ORIGIN=
GALLERY_CONTENT_REGISTRABLE_SITE=
GALLERY_CONTENT_PORT=7460
GALLERY_MANAGEMENT_COOKIE_DOMAIN=
GALLERY_NETWORK_POLICY=deny_external
GALLERY_GRANT_REVISION=
GALLERY_APPEAL_POLICY_REVISION=
GALLERY_CHALLENGE_VERIFIER_READY=false
GALLERY_TURNSTILE_SECRET=
GALLERY_ADMINISTRATOR_AUTHORITY_READY=false
GALLERY_REPORTING_READY=false
GALLERY_NOTIFICATION_READY=false
GALLERY_APPEAL_READY=false
GALLERY_GOVERNANCE_READY=false
GALLERY_ISOLATED_CONTENT_READY=false
BETTER_AUTH_URL=http://127.0.0.1:5173
BETTER_AUTH_SECRET=required-at-least-32-random-characters
MINIMUM_CLI_VERSION=0.1.0
API_UPSTREAM=api:7456

# Loopback-published local ports
POSTGRES_PORT=5432
OBJECT_STORAGE_PORT=9000
OBJECT_STORAGE_CONSOLE_PORT=9001
SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025
API_PORT=7456
GALLERY_CONTENT_PUBLISHED_PORT=7460
WEB_PORT=5173

# PostgreSQL
POSTGRES_DB=shareslices
POSTGRES_USER=shareslices
POSTGRES_PASSWORD=required-database-secret
DATABASE_URL=postgres://shareslices:shareslices@127.0.0.1:5432/shareslices

# S3-compatible object storage
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=shareslices-artifacts
S3_ACCESS_KEY_ID=shareslices
S3_SECRET_ACCESS_KEY=required-object-storage-secret
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=shareslices
MINIO_ROOT_PASSWORD=required-object-storage-secret

# Worker
WORKER_JOB_POLL_INTERVAL_MS=1000
WORKER_JOB_LEASE_SECONDS=30
WORKER_JOB_HEARTBEAT_SECONDS=10
WORKER_JOB_MAX_ATTEMPTS=3
THUMBNAIL_INTERNAL_API_ORIGIN=http://127.0.0.1:7456
CHROMIUM_PATH=chromium

# Private Artifact identity and revision controls
CONTENT_FINGERPRINT_KEY_CURRENT=required-separate-secret-at-least-32-characters
CONTENT_FINGERPRINT_KEY_CURRENT_REVISION=key-v1
# CONTENT_FINGERPRINT_KEY_PREVIOUS=required-previous-secret-at-least-32-characters
# CONTENT_FINGERPRINT_KEY_PREVIOUS_REVISION=key-v0
IDEMPOTENCY_ENCRYPTION_KEY_CURRENT=required-separate-secret-at-least-32-characters
IDEMPOTENCY_ENCRYPTION_KEY_CURRENT_REVISION=key-v1
# IDEMPOTENCY_ENCRYPTION_KEY_PREVIOUS=required-previous-secret-at-least-32-characters
# IDEMPOTENCY_ENCRYPTION_KEY_PREVIOUS_REVISION=key-v0
CONTENT_IDENTITY_REVISION=content-v1
ARTIFACT_PROCESSING_REVISION=processing-v1
ARTIFACT_RENDERER_REVISION=renderer-v2

# Authentication email policy and protected payload encryption
REQUIRE_EMAIL_VERIFICATION=false
AUTH_EMAIL_ENCRYPTION_KEY=required-separate-secret-at-least-32-characters

# SMTP transport. Configure exactly one URL source.
AUTH_EMAIL_SMTP_URL=smtp://127.0.0.1:1025
# AUTH_EMAIL_SMTP_URL_FILE=/run/secrets/auth_email_smtp_url
AUTH_EMAIL_FROM=ShareSlices <no-reply@shareslices.local>
# AUTH_EMAIL_SMTP_CHECK_TO=operator@example.com
AUTH_EMAIL_DELIVERY_LEASE_SECONDS=60
AUTH_EMAIL_SMTP_DNS_TIMEOUT_MS=5000
AUTH_EMAIL_SMTP_CONNECTION_TIMEOUT_MS=10000
AUTH_EMAIL_SMTP_GREETING_TIMEOUT_MS=10000
AUTH_EMAIL_SMTP_SOCKET_TIMEOUT_MS=30000
AUTH_EMAIL_RETRY_DELAY_SECONDS=30

# Authentication email delivery protection
AUTH_EMAIL_RESEND_SECONDS=60
AUTH_EMAIL_PER_EMAIL_HOUR=5
AUTH_EMAIL_PER_EMAIL_DAY=10
AUTH_EMAIL_PER_IP_HOUR=20
AUTH_EMAIL_PER_IP_DAY=100
AUTH_EMAIL_GLOBAL_HOUR=500
AUTH_EMAIL_MAX_ATTEMPTS=3
AUTH_EMAIL_CIRCUIT_BREAKER_SECONDS=300
