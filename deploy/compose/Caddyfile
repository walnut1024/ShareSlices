:8080 {
	handle /internal/* {
		respond 404
	}

	handle /api/* {
		reverse_proxy {$API_UPSTREAM}
	}

	handle /a/* {
		reverse_proxy {$API_UPSTREAM}
	}

	handle /health {
		reverse_proxy {$API_UPSTREAM}
	}

	handle /ready {
		reverse_proxy {$API_UPSTREAM}
	}

	handle /artifacts/*/preview {
		root * /srv
		rewrite * /index.html
		header Cache-Control "no-store"
		file_server
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
